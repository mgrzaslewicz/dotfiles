:set number
:set relativenumber
:imap kj <Esc>
:set so=999
:set cursorline
:set cursorcolumn
:set ignorecase
:set smartcase
set virtualedit=all
if !has('nvim')
  call plug#begin()
    Plug 'mtdl9/vim-log-highlighting'
  call plug#end()
endif

" Enable backup feature
set backup

" Define where backups are stored (double // preserves full path structure)
set backupdir=~/.vim/backup//

" Create backup before overwriting the current buffer
set writebackup

" Customize backup filename to include timestamp (e.g., file.py@2026-05-03.10:30)
autocmd BufWritePre * let &backupext = '@' . strftime("%F.%H:%M")

" Make the highlighted column readable
:highlight CursorColumn ctermfg=Black
:highlight CursorColumn ctermbg=DarkBlue
