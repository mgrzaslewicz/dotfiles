#!/bin/bash
# Machine-specific synchronization script generated by chezmoi

TARGET="{{ .sync_target }}"
SOURCES=(
{{- range .sync_sources }}
    {{ . | quote }}
{{- end }}
)

if [ -n "$TARGET" ]; then
  # Ensure target exists
  mkdir -p "$TARGET"

  # Sync each source into the target directory
  for SOURCE in "${SOURCES[@]}"; do
      if [ -d "$SOURCE" ]; then
          # rsync -a: archive, -u: update, -z: compress
          # --delete: removes files in target that aren't in source
          DIR_NAME=$(basename "$SOURCE")
          TARGET_DIR="$TARGET/$DIR_NAME"
          mkdir -p $TARGET_DIR
          echo "Backing up $SOURCE -> $TARGET_DIR ..."
          rsync -auz --delete "$SOURCE/" "$TARGET_DIR/"
          echo "Backing up $SOURCE -> $TARGET_DIR finished"
      else
          echo "Warning: Source $SOURCE not found or not a directory. Skipping."
      fi
  done
else
  echo "Skipping backup, no backup target configured"
fi


# Special handling for Logseq: commit and push changes
if [ -d "$HOME/Logseq" ]; then
    echo "Processing Logseq repository..."
    pushd "$HOME/Logseq" > /dev/null
    if [ -d ".git" ]; then
        git add .
        # Only commit if there are changes
        if ! git diff-index --quiet HEAD --; then
            git commit -m "Auto save by scheduled job"
            if ! OUTPUT=$(git pull --rebase 2>&1); then
                if git status | grep -q "unmerged paths"; then
                    notify-send "Logseq Backup Error" "Merge conflict detected in Logseq repository. Manual intervention required. Output: $OUTPUT" -u critical
                else
                    echo "Logseq: failed to pull changes. Output: $OUTPUT"
                fi
                git rebase --abort
            fi
            if ! OUTPUT=$(git push 2>&1); then
                notify-send "Logseq Backup Error" "Failed to push Logseq changes to remote. Output: $OUTPUT" -u critical
            fi
        else
            # pull changes regardless if there are no changes to push
            if ! OUTPUT=$(git pull --rebase 2>&1); then
                if git status | grep -q "unmerged paths"; then
                    notify-send "Logseq Backup Error" "Merge conflict detected in Logseq repository. Manual intervention required. Output: $OUTPUT" -u critical
                else
                    echo "Logseq: failed to pull changes. Output: $OUTPUT"
                fi
                git rebase --abort
            fi
            echo "No changes in Logseq to commit."
        fi
    else
        echo "Warning: $HOME/Logseq is not a git repository."
    fi
    popd > /dev/null
fi
