#!/bin/bash
# Machine-specific synchronization script generated by chezmoi

TARGET="{{ .sync_target }}"
SOURCES=(
{{- range .sync_sources }}
    {{ . | quote }}
{{- end }}
)

# Ensure target exists
mkdir -p "$TARGET"

# Sync each source into the target directory
for SOURCE in "${SOURCES[@]}"; do
    if [ -d "$SOURCE" ]; then
        # rsync -a: archive, -u: update, -z: compress
        # --delete: removes files in target that aren't in source
        DIR_NAME=$(basename "$SOURCE")
        mkdir -p "$TARGET/$DIR_NAME"
        rsync -auz --delete "$SOURCE/" "$TARGET/$DIR_NAME/"
    else
        echo "Warning: Source $SOURCE not found or not a directory. Skipping."
    fi
done

# Special handling for Logseq: commit and push changes
if [ -d "$HOME/Logseq" ]; then
    echo "Processing Logseq repository..."
    pushd "$HOME/Logseq" > /dev/null
    if [ -d ".git" ]; then
        git add .
        # Only commit if there are changes
        if ! git diff-index --quiet HEAD --; then
            git commit -m "Auto save by scheduled job"
            if ! git pull --rebase; then
                if git status | grep -q "unmerged paths"; then
                    notify-send "Logseq Backup Error" "Merge conflict detected in Logseq repository. Manual intervention required." -u critical
                else
                    notify-send "Logseq Backup Error" "Failed to pull Logseq changes (network error or other)." -u critical
                fi
                git rebase --abort
            elif ! git push; then
                notify-send "Logseq Backup Error" "Failed to push Logseq changes to remote." -u critical
            fi
        else
            echo "No changes in Logseq to commit."
        fi
    else
        echo "Warning: $HOME/Logseq is not a git repository."
    fi
    popd > /dev/null
fi
