#!/bin/bash
# Machine-specific synchronization script generated by chezmoi

TARGET="{{ .sync_target }}"
SOURCES=(
{{- range .sync_sources }}
    {{ . | quote }}
{{- end }}
)

# Ensure target exists
mkdir -p "$TARGET"

# Sync each source into the target directory
for SOURCE in "${SOURCES[@]}"; do
    if [ -d "$SOURCE" ]; then
        # rsync -a: archive, -u: update, -z: compress
        # --delete: removes files in target that aren't in source
        DIR_NAME=$(basename "$SOURCE")
        mkdir -p "$TARGET/$DIR_NAME"
        rsync -auz --delete "$SOURCE/" "$TARGET/$DIR_NAME/"
    else
        echo "Warning: Source $SOURCE not found or not a directory. Skipping."
    fi
done
